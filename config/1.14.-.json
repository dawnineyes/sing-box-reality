{
  "ntp": {
    "enabled": true,
    "server": "time.apple.com",
    "server_port": 123,
    "interval": "30m"
  },
  "http_clients": [
    {
      "tag": "download"
    }
  ],
  "dns": {
    "servers": [
      {
        "tag": "my_dns",
        "type": "tls",
        "server": "1.1.1.1"
      }
    ],
    "strategy": "prefer_ipv4"
  },
  "certificate_providers": [
    {
      "type": "acme",
      "tag": "acme-certificate",
      "data_directory": "/etc/sing-box/acme",
      "domain": [$domain],
      "default_server_name": $domain,
      "email": $email,
      "provider": "letsencrypt",
      "dns01_challenge": {
        "provider": "cloudflare",
        "api_token": $cf_api_token
      },
      "key_type": "ed25519"
    }
  ],
  "inbounds": [
    {
      "tag": "local-dns-in",
      "type": "direct",
      "listen": "127.53.53.53",
      "listen_port": 53
    },
    {
      "tag": "ss-in",
      "type": "shadowsocks",
      "listen": "::",
      "listen_port": 52001,
      "tcp_fast_open": true,
      "method": "2022-blake3-chacha20-poly1305",
      "password": $ss_pass,
      "multiplex": {
        "enabled": true,
        "padding": true
      }
    },
    {
      "tag": "vless-reality",
      "type": "vless",
      "listen": "::",
      "listen_port": 52002,
      "tcp_fast_open": true,
      "users": [
        {
          "uuid": $uuid,
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "aod.itunes.apple.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "aod.itunes.apple.com",
            "server_port": 443
          },
          "private_key": $private_key,
          "short_id": [ $short_id ]
        }
      }
    },
    {
      "tag": "tuic-in",
      "type": "tuic",
      "listen": "::",
      "listen_port": 52003,
      "users": [
        {
          "name": "umashine",
          "uuid": $uuid,
          "password": $tuic_pass
        }
      ],
      "congestion_control": "bbr",
      "tls": {
        "enabled": true,
        "server_name": $domain,
        "alpn": ["h3"],
        "min_version": "1.3",
        "curve_preferences": ["X25519MLKEM768"],
        "certificate_provider": "acme-certificate"
      }
    },
    {
      "tag": "hy2-in",
      "type": "hysteria2",
      "listen": "::",
      "listen_port": 53000,
      "up_mbps": 100,
      "down_mbps": 100,
      "ignore_client_bandwidth": false,
      "obfs": {
        "type": "salamander",
        "password": $obfs_pass
      },
      "users": [
        {
          "name": "umashine",
          "password": $uuid
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": $domain,
        "alpn": ["h3"],
        "min_version": "1.3",
        "curve_preferences": ["X25519MLKEM768"],
        "certificate_provider": "acme-certificate"
      },
      "masquerade": {
        "type": "proxy",
        "url":"aod.itunes.apple.com"
      },
      "brutal_debug": false
    }
  ],
  "route": {
    "default_domain_resolver": "my_dns",
    "default_http_client": "download",
    "rules": [
      {
        "inbound": [
          "local-dns-in"
        ],
        "action": "hijack-dns"
      },
      {
        "source_ip_cidr": [
          $source_ip_cidr/32
        ],
        "invert": true,
        "action": "reject"
      },
      {
        "ip_is_private": true,
        "action": "reject"
      },
      {
        "inbound":["ss-in"],
        "rule_set": [
          "geoip-cn"
        ],
        "rule_set_ip_cidr_match_source":true,
        "action": "reject"
      },
      {
        "rule_set": ["geolocation-cn"],
        "action": "reject"
      },
      {
        "action": "resolve",
        "server": "my_dns"
      },
      {
        "rule_set": ["geoip-cn"],
        "action": "reject"
      }
    ],
    "rule_set": [
      {
        "tag": "geoip-cn",
        "type": "remote",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/cn.srs",
        "format": "binary",
        "update_interval": "1d"
      },
      {
        "tag": "geolocation-cn",
        "type": "remote",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/geolocation-cn.srs",
        "format": "binary",
        "update_interval": "1d"
      }
    ]
  },
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    }
  ]
}
